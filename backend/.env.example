# ================================================================
#  Indian Script OCR System — Environment Configuration
#
#  SETUP:
#    1. Copy this file:  copy .env.example .env   (Windows)
#                        cp .env.example .env      (Linux/Mac)
#    2. Edit .env with your Tesseract path
#    3. Run: uvicorn app:app --reload --port 8000
# ================================================================

# ── Tesseract OCR Path ────────────────────────────────────────────
# Windows (default install location):
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Windows alternate paths (uncomment if needed):
# TESSERACT_PATH=C:\Program Files (x86)\Tesseract-OCR\tesseract.exe
# TESSERACT_PATH=C:\Users\YourName\AppData\Local\Tesseract-OCR\tesseract.exe

# Linux / macOS — leave blank, auto-detected from PATH:
# TESSERACT_PATH=

# ── Server Settings ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ── Limits ────────────────────────────────────────────────────────
MAX_FILE_MB=25
MAX_REGIONS=30

# ── Logging ───────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
